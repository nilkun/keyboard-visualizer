{
  "layout": [
    ["Alt", "1", "2", "3", "4", "5", "6", "7", "8", "9", "0", "-", "^", "Backspace"],
    ["Tab", "q", "w", "e", "R", "T", "Y", "U", "I", "O", "P", "@", "[", "]"], 
    ["AltGr", "a", "s", "d", "f", "g", "h", "j", "k", "l", ";", ":", "Enter"],
    ["Shift", "Z", "X", "C", "V", "B", "N", "M", ",", ".", "/", "Shift"],
    ["Ctrl", "Esc", "F12", "Win", "Space", "Alt", "Fn", "Ctrl"]
  ],
  "default_key_width": 5,
  "key_widths": {
    "Backspace": 9,
    "Tab": 6,
    "Caps": 6,
    "Enter": 8,
    "Shift": 8,
    "Space": 20
  },
  "highlight_char": "█",
  "normal_char": "░",
  "border_char": "─",
  "highlight_color": "bright_cyan",
  "display_mode": "all",
  "key_labels": {},
  "key_colors": {},
  "key_alternatives": {
    "`": {"base": "`", "shift": "~"},
    "1": {"base": "1", "shift": "!", "altgr": "¹"},
    "2": {"base": "2", "shift": "@", "altgr": "²"},
    "3": {"base": "3", "shift": "#", "altgr": "³"},
    "4": {"base": "4", "shift": "$", "altgr": "€"},
    "5": {"base": "5", "shift": "%"},
    "6": {"base": "6", "shift": "^"},
    "7": {"base": "7", "shift": "&"},
    "8": {"base": "8", "shift": "*"},
    "9": {"base": "9", "shift": "("},
    "0": {"base": "0", "shift": ")"},
    "-": {"base": "-", "shift": "_"},
    "=": {"base": "=", "shift": "+"},
    "[": {"base": "[", "shift": "{"},
    "]": {"base": "]", "shift": "}"},
    "\\": {"base": "\\", "shift": "|"},
    ";": {"base": ";", "shift": ":"},
    "'": {"base": "'", "shift": "\""},
    ",": {"base": ",", "shift": "<"},
    ".": {"base": ".", "shift": ">"},
    "/": {"base": "/", "shift": "?"},
    "E": {"base": "e", "shift": "E", "alt": "é", "altgr": "€"},
    "a": {"base": "a", "shift": "A", "alt": "à", "altgr": "æ"},
    "O": {"base": "o", "shift": "O", "alt": "ó", "altgr": "œ"},
    "U": {"base": "u", "shift": "U", "alt": "ú", "altgr": "ü"},
    "C": {"base": "c", "shift": "C", "altgr": "©"}
  }
}
